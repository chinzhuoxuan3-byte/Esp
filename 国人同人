task.spawn(function()
    while task.wait() do
        local lp = game:GetService("Players").LocalPlayer
        local char = lp.Character
        if char and char:FindFirstChild("HumanoidRootPart") and Config.SpinBot then
            char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(Config.SpinSpeed), 0)
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if Config.HitboxEnabled then
            for _, player in next, game:GetService("Players"):GetPlayers() do
                if player ~= game:GetService("Players").LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = player.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    hrp.Transparency = 0.7
                    hrp.BrickColor = BrickColor.new("Really blue")
                    hrp.CanCollide = false
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(Config.Delay) do
        if Library.Unloaded then break end
        if not (Config.Enabled or Config.TPStick) then continue end
        
        local lp = game:GetService("Players").LocalPlayer
        local char = lp.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
        
        local axe = char:FindFirstChild("Axe")
        
        for _, player in next, game:GetService("Players"):GetPlayers() do
            if player ~= lp and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local targetChar = player.Character
                local targetHRP = targetChar.HumanoidRootPart
                local targetHum = targetChar:FindFirstChild("Humanoid")
                
                if not targetHum or targetHum.Health <= 0 then continue end
                
                if Config.TPStick then
                    char.HumanoidRootPart.CFrame = targetHRP.CFrame
                end
                
                local mag = (char.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                if Config.Enabled and mag <= Config.Range and axe and axe:FindFirstChild("AttackRemote") then
                    axe.AttackRemote:FireServer(unpack({"Start", "Up"}))
                    axe.AttackRemote:FireServer(unpack({"Release", "Up", 1}))
                end
                
                if Config.TPStick then task.wait(0.05) end
            end
        end
    end
end)

task.spawn(function()
    local hue = 0
    local timer = 0
    while task.wait(0.01) do
        if Library.Unloaded then break end
        timer = timer + 0.05
        hue = (hue + 0.5) % 360
        local breath = (math.sin(timer) * 0.15) + 0.85
        local rainbowColor = Color3.fromHSV(hue / 360, 0.75, breath)
        
        Library.AccentColor = rainbowColor
        
        local ui = game:GetService("CoreGui"):FindFirstChild("ScreenGui") or game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("ScreenGui")
        if ui then
            for _, v in next, ui:GetDescendants() do
                if v:IsA("TextLabel") and v.Text == "mspaint" then
                    v.TextColor3 = rainbowColor
                elseif v.Name == "Outline" or v.Name == "TitleBar" or v:IsA("UIStroke") then
                    if v:IsA("Frame") then v.BackgroundColor3 = rainbowColor 
                    elseif v:IsA("UIStroke") then v.Color = rainbowColor end
                end
            end
        end
    end
end)

