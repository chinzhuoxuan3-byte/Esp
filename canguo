local repo = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/"
local Library = loadstring(game:HttpGet(repo .. "Library.lua"))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local RageEnabled = false
local NpcOnly = false
local TargetPart = "Head"
local FireRate = 0
local lastFired = 0
local PredictionAmount = 0.125 

local Window = Library:CreateWindow({ Title = "Ragebot ULTRA", Center = true, AutoShow = true })
local MainTab = Window:AddTab("Main")
local RageGroup = MainTab:AddLeftGroupbox("Rageebkttr")

RageGroup:AddToggle("RageToggle", {
    Text = "Ragebot",
    Default = false,
    Callback = function(Value) RageEnabled = Value end
})

RageGroup:AddToggle("NpcToggle", {
    Text = "NPC",
    Default = false,
    Callback = function(Value) NpcOnly = Value end
})

RageGroup:AddSlider("Predict", {
    Text = "预判强度",
    Default = 12,
    Min = 0,
    Max = 50,
    Rounding = 1,
    Callback = function(Value) PredictionAmount = Value / 100 end
})

local function GetTarget()
    local target = nil
    local dist = math.huge
    
    local candidates = {}
    
    if NpcOnly then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Humanoid") and v.Parent and v.Parent:IsA("Model") and not Players:GetPlayerFromCharacter(v.Parent) then
                table.insert(candidates, v.Parent)
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character then
                table.insert(candidates, v.Character)
            end
        end
    end
    
    for _, char in pairs(candidates) do
        local p = char:FindFirstChild(TargetPart)
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if p and hum and hum.Health > 0 and root then
            local mag = (p.Position - LocalPlayer.Character.PrimaryPart.Position).Magnitude
            if mag < dist then
                dist = mag
                target = {part = p, root = root}
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if not RageEnabled or not LocalPlayer.Character then return end
    
    local now = tick()
    if now - lastFired < FireRate then return end
    
    local targetData = GetTarget()
    local tool = LocalPlayer.Character:FindFirstChild("No Scope Rifle 2.0") or LocalPlayer.Backpack:FindFirstChild("No Scope Rifle 2.0")
    
    if targetData and tool then
        local remote = tool:FindFirstChild("RemoteEvent")
        if remote then
            local velocity = targetData.root.Velocity
            local predictedPos = targetData.part.Position + (velocity * PredictionAmount)
            
            local args = {
                predictedPos,
                3000
            }
            
            remote:FireServer(unpack(args))
            lastFired = now
        end
    end
end)

Library:Notify("Ragebot")
